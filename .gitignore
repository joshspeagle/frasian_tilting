# Experiment results (regenerable via scripts/run.py + figures.py)
results/

# Superpowers brainstorming artefacts (design specs, drafts) — kept
# local so the git tree stays scoped to source/tests/docs/methods only.
docs/superpowers/

# Phase G v4 learned-η fixtures: gitignored because conditional
# checkpoints are larger and trivially re-trainable from the YAMLs
# in `experiments/canonical_*_v4.yaml`. Train via:
#     python -m scripts.train_learned_eta \
#         --config experiments/canonical_<scheme>_v4.yaml \
#         --out artifacts/learned_eta_canonical_<scheme>_v4.eqx
artifacts/learned_eta_*_v4.eqx
# Production training-time diagnostics sidecars (paired with the .eqx
# checkpoints; same regenerability rationale).
artifacts/learned_eta_*_v4.diagnostics.json
# Probe / smoke / diagnostic checkpoints (gitignored — train locally)
artifacts/probe_v4_*.eqx
artifacts/probe_v4_*.diagnostics.json
artifacts/probe_pl_*.eqx
# Diagnostic .npz outputs from probe scripts (regenerable by re-running
# the corresponding `scripts/probe_*.py`). Includes per_theta_test_argmin,
# v4_hyperparam_audit, single_slice_*, two_slice_discrim, continuous_kd,
# etc.
artifacts/*.npz

# Temporary files
*.tmp
*.temp
*.bak

# Log files
*.log

# Claude session caches (transient).
# Note: .claude/agents/ and .claude/commands/ ARE committed — they hold the
# subagent definitions and slash commands that codify the framework's
# critique / literature-review / derivation workflow.
.claude/*
!.claude/agents/
!.claude/agents/**
!.claude/commands/
!.claude/commands/**

# Audit artifacts (Tier 0/1/2/3 multi-agent code audit outputs)
audit/
!docs/audit/
!docs/audit/**
